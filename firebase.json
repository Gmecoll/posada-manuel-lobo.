{
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log"
      ]
    }
  ],
  "hosting": {
    "public": "public",
    "rewrites": [
      {
        "source": "/api/**",
        "function": "iniciarPagoServicio"
      },
      {
        "source": "**",
        "run": {
          "serviceId": "posada-manuel-lobo-guest-app",
          "region": "us-west1"
        }
      }
    ]
  }
}